{
  "_comment": "예시 config — 본인 데이터셋 경로로 수정해서 사용",

  "model_dir": "/path/to/ECGFMs",

  "models": null,

  "target_fs": 500,
  "target_length": 5000,

  "datasets": [
    {
      "name": "MyDataset",
      "h5_root": "/path/to/h5",
      "table_csv": "/path/to/h5/my_table.csv",
      "label_csv": "/path/to/my_labels.csv",
      "label_col": "NORM",
      "age_col": "age",
      "age_scale": 100,
      "display_color": "#1f77b4",
      "display_marker": "o"
    }
  ],

  "age_bins": [
    [0,   3,   "#CC79A7"],
    [3,   6,   "#9400D3"],
    [6,   12,  "#D55E00"],
    [12,  18,  "#F0E442"],
    [18,  40,  "#0072B2"],
    [40,  60,  "#009E73"],
    [60,  80,  "#E69F00"],
    [80,  200, "#000000"]
  ]
}
